{
  "name": "hantatrack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/api/index.ts",
    "dev:server": "tsx watch src/server/api/index.ts",
    "build": "tsc -b && npm run build:client && npm run build:server",
    "build:client": "cross-env NODE_ENV=production vite build --outDir dist/client",
    "build:server": "cross-env NODE_ENV=production vite build --ssr src/entry-server.tsx --outDir dist/server",
    "lint": "eslint .",
    "preview": "vite preview",
    "scraper": "tsx src/server/scraper/cli.ts",
    "scraper:cleanup": "tsx src/server/scraper/cleanup-cli.ts",
    "scraper:worker": "tsx src/server/scraper/worker.ts",
    "start": "cross-env NODE_ENV=production tsx src/server/api/index.ts",
    "server": "tsx src/server/api/index.ts",
    "server:dev": "tsx watch src/server/api/index.ts",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^1.1.46",
    "@langchain/openai": "^1.4.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.8.0",
    "helmet": "^8.1.0",
    "langchain": "^1.4.0",
    "leaflet": "^1.9.4",
    "p-limit": "^7.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
