# Copy to .env and fill in the values you have.
# Anything left blank will fall back to safe defaults (no AI, mock data).

# ─── OpenAI / LangChain ───────────────────────────────────────────────
# When set, news/unstructured sources will use LangChain + OpenAI to
# extract structured case data from article text. When unset, those
# sources fall back to hardcoded seeds.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000

# ─── Scraper worker ───────────────────────────────────────────────────
# How often the worker loop runs the full scrape, in minutes.
SCRAPER_INTERVAL_MINUTES=60
# Per-source fetch timeout
SCRAPER_FETCH_TIMEOUT_MS=30000
# Where the scraper writes the canonical GeoJSON dataset. The API reads it.
SCRAPER_OUTPUT_PATH=data/cases.geojson

# ─── Express API server ──────────────────────────────────────────────
PORT=8080
NODE_ENV=development
# Comma-separated origins allowed to call /api/*. The API is same-origin only;
# put your front-end's origin(s) here. In dev, include the Vite ports.
CORS_ALLOWED_ORIGINS=https://hantatrack.net,https://www.hantatrack.net
# Set to "true" only when running behind a trusted reverse proxy.
TRUST_PROXY=false

# ─── Live updates (SSE) ──────────────────────────────────────────────
# Heartbeat interval (ms) for the /api/v1/updates stream. Must be lower than
# your reverse proxy's idle timeout (commonly 30-60s).
SSE_HEARTBEAT_INTERVAL_MS=25000

